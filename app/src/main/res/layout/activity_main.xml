<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="24dp">

    <!-- Status dot -->
    <TextView
        android:id="@+id/tvDot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="●"
        android:textSize="32sp"
        android:textColor="#FF4444"
        android:fontFamily="monospace"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="64dp" />

    <!-- Status label -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/disconnected"
        android:textSize="16sp"
        android:textColor="#666666"
        android:fontFamily="monospace"
        android:letterSpacing="0.1"
        app:layout_constraintTop_toBottomOf="@id/tvDot"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp" />

    <!-- IP input -->
    <EditText
        android:id="@+id/etIp"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:hint="@string/hint_ip"
        android:inputType="textUri"
        android:fontFamily="monospace"
        android:textColor="#00FF00"
        android:textColorHint="#666666"
        android:background="#111111"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="64dp" />

    <!-- Connect button -->
    <Button
        android:id="@+id/btnConnect"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/btn_connect"
        android:textAllCaps="true"
        android:textColor="#00FF00"
        android:textSize="16sp"
        android:fontFamily="monospace"
        app:strokeColor="#00FF00"
        app:strokeWidth="1dp"
        app:backgroundTint="#111111"
        app:layout_constraintTop_toBottomOf="@id/etIp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp" />

    <!-- Test buttons (rehearsal) -->
    <TextView
        android:id="@+id/tvTestLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ENSAYO"
        android:textSize="11sp"
        android:textColor="#444444"
        android:fontFamily="monospace"
        android:letterSpacing="0.15"
        app:layout_constraintBottom_toTopOf="@id/btnTestVibrate"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnTestVibrate"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:text="VIBRAR"
        android:textColor="#FFAA00"
        android:textSize="13sp"
        android:fontFamily="monospace"
        app:strokeColor="#FFAA00"
        app:strokeWidth="1dp"
        app:backgroundTint="#111111"
        app:layout_constraintBottom_toTopOf="@id/btnTestSound"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnTestSound"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:text="SONIDO"
        android:textColor="#00AAFF"
        android:textSize="13sp"
        android:fontFamily="monospace"
        app:strokeColor="#00AAFF"
        app:strokeWidth="1dp"
        app:backgroundTint="#111111"
        app:layout_constraintBottom_toTopOf="@id/btnTestRedScreen"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnTestRedScreen"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:text="PANTALLA ROJA"
        android:textColor="#FF4444"
        android:textSize="13sp"
        android:fontFamily="monospace"
        app:strokeColor="#FF4444"
        app:strokeWidth="1dp"
        app:backgroundTint="#111111"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="32dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
